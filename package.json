{
  "name": "skillfixture",
  "version": "0.1.0",
  "description": "Generate deterministic fixture packs from agent skill examples.",
  "type": "module",
  "bin": {
    "skillfixture": "./bin/skillfixture.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/index.js && node --check bin/skillfixture.js",
    "smoke": "node bin/skillfixture.js test/fixtures/source/SKILL.md --dry-run",
    "validate": "bash scripts/validate.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agents",
    "skills",
    "fixtures",
    "regression",
    "cli"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/skillfixture.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/skillfixture/issues"
  },
  "homepage": "https://github.com/rogerchappel/skillfixture#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ]
}
